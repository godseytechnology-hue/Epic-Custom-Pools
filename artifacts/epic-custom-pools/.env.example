# Epic Custom Pools — Environment Variables
# Copy this file to .env.local and fill in real values before launch.
# All NEXT_PUBLIC_* vars are safe to expose to the browser.

# Site URL — Replit preview URL in dev, custom domain at launch (Sprint 7)
# Updating this one variable auto-updates every canonical URL, sitemap entry,
# and Open Graph tag across the entire site.
NEXT_PUBLIC_SITE_URL=https://epiccustompools.com

# Google Analytics 4 Measurement ID (from analytics.google.com)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Contact Information
NEXT_PUBLIC_PHONE=(817) 555-0100
NEXT_PUBLIC_EMAIL=info@epiccustompools.com

# Business Details
NEXT_PUBLIC_SITE_NAME=Epic Custom Pools
NEXT_PUBLIC_TAGLINE=Fort Worth's Premier Custom Pool Builder
NEXT_PUBLIC_ADDRESS=Fort Worth, TX

# Service Cities — comma-separated list used in footer, city pages, and JSON-LD schema.
# To add or remove a city, update this value without touching any code.
NEXT_PUBLIC_SERVICE_CITIES=Fort Worth,Weatherford,Aledo,Granbury,Mineral Wells,Benbrook,Hudson Oaks,Burleson

# -----------------------------------------------------------------------
# Sprint 6+ (Lead Form & Email Integration) — not needed until Sprint 6
# -----------------------------------------------------------------------
# Resend API key (server-side only — no NEXT_PUBLIC_ prefix)
# Used for lead form email notifications when the consultation form is built.
RESEND_API_KEY=re_XXXXXXXXXX
RESEND_TO_EMAIL=owner@epiccustompools.com
